# ═══════════════════════════════════════════════════════════════
# CAVAVIN Backend — Variables d'environnement
# Copier ce fichier en .env et remplir les valeurs
# ═══════════════════════════════════════════════════════════════

# Connexion AIVEN PostgreSQL (URI complète)
# Trouver dans AIVEN Console → Service URI (avec le mot de passe)
AIVEN_PG_URL=postgres://avnadmin:MOT_DE_PASSE@pg-eed0e02-pbesnet-4cb8.e.aivencloud.com:28140/defaultdb?sslmode=require

# Clé secrète pour signer les JWT (génère une chaîne aléatoire longue)
# Ex: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change-moi-avec-une-longue-chaine-aleatoire

# Port d'écoute (Render utilise la variable PORT automatiquement)
PORT=3000

# Origine autorisée pour CORS (URL de ton app HTML déployée)
# En dev, utilise * ; en prod, mets l'URL exacte
CORS_ORIGIN=*

# (Optionnel) Clé Anthropic directement dans l'env (sinon stockée en DB)
# ANTHROPIC_API_KEY=sk-ant-...
